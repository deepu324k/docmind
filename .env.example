# Groq API Key (free tier) — get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API Token (fallback) — get from https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here

# Flask secret key
SECRET_KEY=change-this-to-a-random-string

# Port (set by hosting platform)
PORT=5000
